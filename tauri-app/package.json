{
  "name": "xolotl-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "build:mac": "tauri build --bundles app",
    "build:mac:dmg": "npm run build:mac && npm run package:mac:dmg",
    "build:mac:universal": "tauri build --target universal-apple-darwin --bundles app",
    "build:mac:universal:dmg": "npm run build:mac:universal && MAC_DMG_ARCH=universal npm run package:mac:dmg",
    "package:mac:dmg": "node scripts/package-mac-dmg.mjs",
    "open:mac": "open 'src-tauri/target/release/bundle/macos/Xolotl Code.app'",
    "civ:codex-play": "node scripts/codex-play-civ.mjs",
    "civ:watch-demo": "node scripts/codex-play-civ.mjs --in-app-pilot --goal task-loop --steps 80 --headed --slow-mo 20 --sample-ms 900 --screenshot-dir output/web-game/civ-watch-demo --screenshot-every 8 --stop-after-completions 5 --fail-on-critical-oxygen --max-no-progress 18 --keep-open 30"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "diff": "^9.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "phaser": "^4.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
