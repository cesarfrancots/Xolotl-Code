{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Xolotl Code",
  "version": "0.1.0",
  "identifier": "com.xolotl.code",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xolotl Code",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 15
        },
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop coding agent platform for evaluating and racing LLMs.",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
